# EventHub — root environment template. Copy to .env and fill. NEVER commit .env or real secrets.
# All secret values below are placeholders — replace locally. Use long random strings for tokens/secrets.

# --- Database (MySQL, one DB per service) ---
# Dev-only defaults. CHANGE DB_ROOT_PASSWORD and DB_PASSWORD for any non-local environment.
DB_ROOT_PASSWORD=eventhub_root_dev
DB_USERNAME=eventhub
DB_PASSWORD=eventhub_dev
CORE_DB_DATABASE=eventhub_core
PAYMENTS_DB_DATABASE=eventhub_payments
NOTIFICATIONS_DB_DATABASE=eventhub_notifications

# --- Redis (queues + distributed locks) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Inter-service auth (shared secrets / tokens) ---
# These dev-only values work out of the box locally. CHANGE THEM for any non-local environment.
# Generate new ones with: openssl rand -hex 32
# core-api -> payment-service bearer token
PAYMENT_SERVICE_TOKEN=dev-only-payment-service-token-change-in-production
# payment-service -> core-api webhook bearer token
CORE_API_BEARER_TOKEN=dev-only-core-api-bearer-token-change-in-production
# payment-service -> core-api webhook HMAC signing secret
CORE_API_WEBHOOK_SECRET=dev-only-core-api-webhook-secret-change-in-production
# notification-service vendor-webhook signing secret
VENDOR_WEBHOOK_SECRET=dev-only-vendor-webhook-secret-change-in-production

# --- Inter-service callback URLs ---
CORE_API_WEBHOOK_URL=http://core-api:8000/api/v1/internal/payments/webhook
CORE_API_REFUND_WEBHOOK_URL=http://core-api:8000/api/v1/internal/payments/refund-webhook
CORE_API_PAYOUT_WEBHOOK_URL=http://core-api:8000/api/v1/internal/payments/payout-webhook

# --- Payment gateway simulation (tunable success/failure rates for testing) ---
GATEWAY_STRIPE_SUCCESS_RATE=0.9
GATEWAY_PAYPAL_SUCCESS_RATE=0.85
PAYMENT_WEBHOOK_DELAY_SECONDS=2

# --- Platform business config ---
PLATFORM_COMMISSION_RATE=0.10
MINIMUM_PAYOUT_THRESHOLD=50000        # minor units (e.g. 500.00 in 2-decimal currency)
DEFAULT_CURRENCY=BDT
TICKET_HOLD_MINUTES=15

# --- App keys (generated per Laravel service: php artisan key:generate) ---
# Left empty so the docker-entrypoint auto-generates a fresh key on first boot.
# For the local / Laragon path run: php artisan key:generate
CORE_APP_KEY=
PAYMENTS_APP_KEY=
