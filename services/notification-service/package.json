{
  "name": "notification-service",
  "version": "1.0.0",
  "description": "EventHub notification microservice — BullMQ queue consumer for email (simulated) and vendor webhooks",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node --project tsconfig.json src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts --max-warnings 0",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bullmq": "^5.8.1",
    "express": "^4.19.2",
    "ioredis": "^5.3.2",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "nock": "^13.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
