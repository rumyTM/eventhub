NODE_ENV=development
PORT=8002
LOG_LEVEL=info

# Redis (shared with core-api and payment-service)
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# HMAC signing secret for vendor webhooks — must match the secret registered per vendor
# Never log or expose this value; use [PLACEHOLDER] in examples
VENDOR_WEBHOOK_SECRET=[PLACEHOLDER]

# Queue names (must match what core-api publishes to)
NOTIFICATIONS_QUEUE=eventhub:notifications
WEBHOOKS_QUEUE=eventhub:webhooks
DEAD_LETTER_QUEUE=eventhub-dead-letter

# Internal BullMQ processing queues (BullMQ v5 forbids ':' in names)
NS_NOTIFICATIONS_QUEUE=ns-notifications
NS_WEBHOOKS_QUEUE=ns-webhooks
