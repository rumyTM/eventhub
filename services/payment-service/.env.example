APP_NAME=EventHub-payment-service
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=eventhub_payments
DB_USERNAME=root
DB_PASSWORD=[PLACEHOLDER]

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- EventHub: inter-service auth -------------------------------------------------
# Shared secret core-api presents on every money call (EnsureServiceToken). Generate a
# strong random value per environment; never commit the real one.
PAYMENT_SERVICE_TOKEN=[PLACEHOLDER]

# --- EventHub: outbound webhook to core-api ----------------------------------------
# Where this service reports the terminal charge result. The bearer token authenticates
# the call; the webhook secret is a SEPARATE key that HMAC-signs the body (X-Signature)
# so a leaked Authorization header can't forge a signature. A fixed, trusted URL — never
# taken from a request body. Generate strong, distinct random secrets per environment.
CORE_API_WEBHOOK_URL=http://core-api:8000/api/v1/internal/payments/webhook
# Where this service reports the terminal REFUND result (separate endpoint; same bearer + HMAC secret).
CORE_API_REFUND_WEBHOOK_URL=http://core-api:8000/api/v1/internal/payments/refund-webhook
# Separate endpoint for the terminal payout result; same bearer + HMAC secret pair.
CORE_API_PAYOUT_WEBHOOK_URL=http://core-api:8000/api/v1/internal/payments/payout-webhook
CORE_API_BEARER_TOKEN=[PLACEHOLDER]
CORE_API_WEBHOOK_SECRET=[PLACEHOLDER]

# --- EventHub: simulated gateways (NEVER a real gateway / no card data) ------------
# success_rate is a fraction in [0,1]; failure_rate is its complement. force/seed make
# outcomes deterministic for tests/dev only — they hold no secrets.
PAYMENT_GATEWAY_DEFAULT=stripe_sim

GATEWAY_STRIPE_SUCCESS_RATE=0.9
GATEWAY_STRIPE_DELAY_SECONDS=0
# GATEWAY_STRIPE_FORCE=        # succeed|fail (overrides the rate)
# GATEWAY_STRIPE_SEED=         # int (reproducible rate-based rolls)

GATEWAY_PAYPAL_SUCCESS_RATE=0.85
GATEWAY_PAYPAL_DELAY_SECONDS=0
# GATEWAY_PAYPAL_FORCE=
# GATEWAY_PAYPAL_SEED=
